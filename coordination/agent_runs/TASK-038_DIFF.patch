+                    "live HKEX trading-calendar source unavailable in current environment: "
+                    f"{type(exc).__name__}: {exc}"
+                )
+            raise
+
+        if result.record_count < 1:
+            self.skipTest(
+                "live HKEX trading-calendar source returned no usable bounded sample records"
+            )
+
+        first_record = result.normalized_records[0]
+        issues = registry.validate_record(DatasetName.TRADING_CALENDAR, first_record)
+        self.assertEqual(issues, ())
+        self.assertEqual(first_record["source"], HKEX_SOURCE_ID)
