+import os
+import socket
+import unittest
+from datetime import date, timedelta
+from typing import Iterable
+from urllib.error import HTTPError, URLError
+
+from quant.datahub.adapters.hkex import (
+    HKEX_SOURCE_ID,
+    HkexHKTradingCalendarAdapter,
+)
+from quant.datahub.datasets import DatasetName, DatasetRegistry
+from quant.datahub.source import SourceRequest, fetch_source_result
+
+
+LIVE_TESTS_ENABLED = os.getenv("QUANT_SYSTEM_LIVE_TESTS") == "1"
+
+
+def _exception_chain(exc: BaseException) -> Iterable[BaseException]:
+    seen: set[int] = set()
+    current: BaseException | None = exc
+    while current is not None and id(current) not in seen:
+        seen.add(id(current))
+        yield current
+        if current.__cause__ is not None:
+            current = current.__cause__
+            continue
+        current = current.__context__
+
+
+def _is_live_environment_unavailable(exc: BaseException) -> bool:
+    network_exception_names = {
+        "ProxyError",
+        "ConnectionError",
+        "ConnectTimeout",
+        "ReadTimeout",
+        "Timeout",
+        "MaxRetryError",
+        "NewConnectionError",
+        "NameResolutionError",
+        "SSLError",
+    }
+    network_message_tokens = (
+        "proxy",
+        "timed out",
+        "timeout",
+        "name resolution",
+        "temporary failure in name resolution",
+        "failed to establish a new connection",
+        "max retries exceeded",
+        "network is unreachable",
+        "connection refused",
+        "no route to host",
+        "connection reset",
+        "dns",
+        "hkex.com.hk",
+        "subscribe-calendar",
+        "hkex-calendar.ics",
+    )
+
+    for cause in _exception_chain(exc):
+        name = type(cause).__name__
+        module = type(cause).__module__
+        message = str(cause).lower()
+
+        if isinstance(cause, (URLError, HTTPError)):
+            return True
+        if name in network_exception_names:
+            return True
+        if module.startswith(("requests", "urllib3")) and any(
+            token in message for token in network_message_tokens
+        ):
+            return True
+        if isinstance(cause, (socket.timeout, TimeoutError, ConnectionError)):
+            return True
+        if isinstance(cause, OSError):
+            if cause.errno in {101, 104, 110, 111, 113}:
+                return True
+            if any(token in message for token in network_message_tokens):
+                return True
+
+    return False
+
+
+class HkexHKTradingCalendarLiveClassifierTests(unittest.TestCase):
+    def test_classifier_treats_network_errors_as_environment_issue(self) -> None:
+        self.assertTrue(
+            _is_live_environment_unavailable(
+                OSError(111, "connection refused to www.hkex.com.hk")
+            )
+        )
+
+    def test_classifier_keeps_contract_failures_as_non_environment_issue(self) -> None:
+        self.assertFalse(_is_live_environment_unavailable(ValueError("Invalid trade date value")))
+
+
+class HkexHKTradingCalendarLiveTests(unittest.TestCase):
+    @unittest.skipUnless(
+        LIVE_TESTS_ENABLED,
