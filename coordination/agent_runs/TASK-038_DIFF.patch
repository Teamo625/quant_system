+    def test_live_hkex_hk_trading_calendar_smoke(self) -> None:
+        adapter = HkexHKTradingCalendarAdapter()
+        registry = DatasetRegistry()
+
+        range_start = date.today().replace(month=1, day=1)
+        range_end = range_start + timedelta(days=45)
+
+        request = SourceRequest(
+            dataset=DatasetName.TRADING_CALENDAR,
+            source_name=HKEX_SOURCE_ID,
+            start_date=range_start,
+            end_date=range_end,
+        )
+
+        try:
+            result = fetch_source_result(adapter, request)
+        except Exception as exc:
